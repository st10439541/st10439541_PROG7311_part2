@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center">
    <h1 class="display-4">Welcome to TechMove Logistics</h1>
    <p class="lead">Global Logistics Management System (GLMS)</p>
    <hr />
</div>

@if (!User.Identity.IsAuthenticated)
{
    <div class="alert alert-info text-center">
        <h4>Please <a asp-controller="Account" asp-action="Login">Login</a> or <a asp-controller="Account" asp-action="Register">Register</a> to access the system features.</h4>
    </div>

    <!-- Demo Credentials Section - Two Columns -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <strong>Admin Account</strong>
                </div>
                <div class="card-body">
                    <p><strong>Email:</strong> admin@techmove.com</p>
                    <p><strong>Password:</strong> Admin@123</p>
                    <p><strong>Role:</strong> Administrator</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <strong>Client Account</strong>
                </div>
                <div class="card-body">
                    <p><strong>Email:</strong> example@gmail.com</p>
                    <p><strong>Password:</strong> 123456</p>
                    <p><strong>Role:</strong> Client</p>
                </div>
            </div>
        </div>
    </div>
}

<!-- Three Feature Cards - Always Visible -->
<div class="row mt-4">
    <!-- Only show Clients card for Admin users when logged in, but show for everyone when not logged in -->
    @if (!User.Identity.IsAuthenticated || User.IsInRole("Admin"))
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-people"></i> Clients
                    </h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Manage your clients, including their contact details, addresses, and regional information.</p>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle-fill text-success"></i> Add new clients</li>
                        <li><i class="bi bi-check-circle-fill text-success"></i> Update client information</li>
                        <li><i class="bi bi-check-circle-fill text-success"></i> View client contracts</li>
                    </ul>
                </div>
                <div class="card-footer bg-transparent">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Clients" asp-action="Index" class="btn btn-primary w-100">View Clients</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary w-100">Login to View</a>
                    }
                </div>
            </div>
        </div>
    }

    <div class="col-md-4 mb-3">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="bi bi-file-text"></i> Contracts
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">View and manage contracts. Clients can sign pending contracts to activate them.</p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check-circle-fill text-success"></i> View all contracts</li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li><i class="bi bi-check-circle-fill text-success"></i> Create new contracts</li>
                        <li><i class="bi bi-check-circle-fill text-success"></i> Upload PDF agreements</li>
                    }
                    else
                    {
                        <li><i class="bi bi-check-circle-fill text-success"></i> Sign pending contracts</li>
                    }
                    <li><i class="bi bi-check-circle-fill text-success"></i> Filter by date and status</li>
                </ul>
            </div>
            <div class="card-footer bg-transparent">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Contracts" asp-action="Index" class="btn btn-success w-100">View Contracts</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-success w-100">Login to View</a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="bi bi-truck"></i> Service Requests
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">Create service requests with automatic USD to ZAR currency conversion using real-time exchange rates.</p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check-circle-fill text-success"></i> Real-time currency conversion</li>
                    <li><i class="bi bi-check-circle-fill text-success"></i> Active contract validation</li>
                    <li><i class="bi bi-check-circle-fill text-success"></i> Track request status</li>
                </ul>
            </div>
            <div class="card-footer bg-transparent">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-info text-white w-100">View Service Requests</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-info text-white w-100">Login to View</a>
                }
            </div>
        </div>
    </div>
</div>

@if (User.Identity.IsAuthenticated)
{
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Clients" asp-action="Create" class="btn btn-outline-primary">
                                <i class="bi bi-person-plus"></i> Add New Client
                            </a>
                            <a asp-controller="Contracts" asp-action="Create" class="btn btn-outline-success">
                                <i class="bi bi-file-plus"></i> Create New Contract
                            </a>
                        }
                        <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-outline-info">
                            <i class="bi bi-plus-circle"></i> Create Service Request
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">System Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td><strong>Current Date:</strong></td>
                            <td>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</td>
                        </tr>
                        <tr>
                            <td><strong>Current Time:</strong></td>
                            <td>@DateTime.Now.ToString("hh:mm tt")</td>
                        </tr>
                        <tr>
                            <td><strong>System Version:</strong></td>
                            <td>1.0.0</td>
                        </tr>
                        <tr>
                            <td><strong>Currency Support:</strong></td>
                            <td>USD → ZAR (Real-time)</td>
                        </tr>
                        <tr>
                            <td><strong>Document Support:</strong></td>
                            <td>PDF Uploads (Max 10MB)</td>
                        </tr>
                        <tr>
                            <td><strong>Logged in as:</strong></td>
                            <td>@User.Identity.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Role:</strong></td>
                            <td>@(User.IsInRole("Admin") ? "Administrator" : "Client")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<!-- Business Rules Section -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Business Rules & System Overview</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="alert alert-info">
                            <strong>Rule 1: Contract Status Validation</strong>
                            <p class="mb-0 small">Service requests can ONLY be created for contracts with status "Active". Contracts that are "Expired", "Draft", or "On Hold" cannot have service requests created against them.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-info">
                            <strong>Rule 2: Currency Conversion</strong>
                            <p class="mb-0 small">When creating a service request, the USD amount entered is automatically converted to ZAR using real-time exchange rates from a free external API (ExchangeRate-API). The exchange rate used is saved with each service request for audit purposes.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-info">
                            <strong>Rule 3: Document Upload Validation</strong>
                            <p class="mb-0 small">Only PDF files are accepted for contract agreements. The system validates both the file extension (.pdf) AND the actual file content (PDF magic bytes) to ensure it's a genuine PDF. Maximum file size is 10MB.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detailed Explanation Section -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">System Functionality & Architecture Explanation</h5>
            </div>
            <div class="card-body">
                <h6>1. Client Management Module</h6>
                <p>The Client Management module allows administrators to maintain a database of all clients. Each client record stores:</p>
                <ul>
                    <li><strong>Company Name</strong> - The client's business name</li>
                    <li><strong>Contact Information</strong> - Email address and phone number for primary contact</li>
                    <li><strong>Address</strong> - Physical location of the client</li>
                    <li><strong>Region</strong> - Geographic region for reporting purposes</li>
                </ul>
                <p>Clients serve as the parent entity for all contracts and service requests in the system. When a client is deleted, all associated contracts and service requests are also removed (cascade delete).</p>

                <hr />

                <h6>2. Contract Management Module</h6>
                <p>The Contract Management module handles all agreements between TechMove and its clients. Key features include:</p>
                <ul>
                    <li><strong>Contract Lifecycle</strong> - Contracts can have status: Draft, PendingClientSignature, Active, Expired, or On Hold</li>
                    <li><strong>Service Levels</strong> - Three tiers available: Standard, Premium, or Enterprise</li>
                    <li><strong>Date Range</strong> - Each contract has a start date and end date defining its validity period</li>
                    <li><strong>PDF Agreement Upload</strong> - Signed contracts can be uploaded as PDF files (validated for authenticity)</li>
                    <li><strong>Search & Filter</strong> - Users can filter contracts by date range and status using LINQ queries</li>
                    <li><strong>Client Signing</strong> - Clients must sign contracts before they become active</li>
                </ul>
                <p>The system automatically checks if a contract is expired based on both the status and the end date. Only Active contracts allow creation of service requests.</p>

                <hr />

                <h6>3. Service Request Module</h6>
                <p>The Service Request module manages operational requests from clients. Important aspects include:</p>
                <ul>
                    <li><strong>Workflow Validation</strong> - Before creating a request, the system verifies the parent contract is Active (not Expired or On Hold)</li>
                    <li><strong>Currency Conversion</strong> - Real-time USD to ZAR conversion using external ExchangeRate-API</li>
                    <li><strong>Request Status</strong> - Requests can be Pending, In Progress, Completed, or Cancelled</li>
                    <li><strong>Audit Trail</strong> - The exchange rate used for conversion is stored with each request</li>
                </ul>
                <p>The currency conversion uses an external API call via HttpClient. The rate is cached for 60 minutes to reduce API calls and improve performance.</p>

                <hr />

                <h6>4. Technical Architecture</h6>
                <p>The system is built using the following technologies and patterns:</p>
                <ul>
                    <li><strong>ASP.NET Core MVC</strong> - Model-View-Controller architecture for clean separation of concerns</li>
                    <li><strong>Entity Framework Core</strong> - ORM for database operations with SQL Server</li>
                    <li><strong>Dependency Injection</strong> - Services are registered in Program.cs and injected into controllers</li>
                    <li><strong>Repository Pattern</strong> - Database operations are handled through DbContext</li>
                    <li><strong>Unit Testing</strong> - xUnit tests for business logic validation (currency calculation, file validation, workflow rules)</li>
                </ul>

                <hr />

                <h6>5. Role-Based Access Control</h6>
                <ul>
                    <li><strong>Administrator Role</strong> - Full access to create, edit, delete all clients, contracts, and service requests</li>
                    <li><strong>Client Role</strong> - Can view their own contracts, sign pending contracts, and create service requests on active contracts</li>
                    <li><strong>Unauthenticated Users</strong> - Can only view the home page and login/register</li>
                </ul>

                <hr />

                <h6>6. Data Validation Rules</h6>
                <ul>
                    <li><strong>File Validation</strong> - PDF files only, content verification via magic bytes (%PDF header), max 10MB size</li>
                    <li><strong>Business Validation</strong> - Service requests blocked for non-active contracts</li>
                    <li><strong>Data Annotations</strong> - Required fields, string lengths, email format, phone numbers, and date ranges</li>
                </ul>

                <hr />

                <h6>7. External API Integration</h6>
                <p>The system integrates with a free Currency Exchange API (ExchangeRate-API) to fetch real-time USD to ZAR exchange rates. Features include:</p>
                <ul>
                    <li><strong>Async/Await</strong> - Non-blocking API calls for better performance</li>
                    <li><strong>Caching</strong> - Exchange rates are cached in memory for 60 minutes to reduce external API calls</li>
                    <li><strong>Fallback Rate</strong> - If the API fails, a default rate (19.50 ZAR/USD) is used to prevent system failure</li>
                    <li><strong>AJAX Support</strong> - The Create Service Request page fetches the latest rate dynamically without page refresh</li>
                </ul>

                <hr />

                <h6>8. File Handling System</h6>
                <p>Contract PDFs are handled as follows:</p>
                <ul>
                    <li><strong>Upload</strong> - Files are saved to wwwroot/uploads/contracts/ with unique GUID filenames</li>
                    <li><strong>Download</strong> - Files can be downloaded via the DownloadPdf action method</li>
                    <li><strong>Validation</strong> - Both extension and content validation ensure only real PDFs are stored</li>
                    <li><strong>Storage Path</strong> - The file path is stored in the database for retrieval</li>
                </ul>

                <hr />

                <h6>9. Unit Testing Coverage</h6>
                <p>The solution includes comprehensive unit tests covering:</p>
                <ul>
                    <li><strong>Currency Conversion Tests</strong> - Verifying USD to ZAR math calculations with various inputs (including zero and edge cases)</li>
                    <li><strong>File Validation Tests</strong> - Testing PDF validation (valid PDFs, EXE files, TXT files, empty files, large files, fake PDFs)</li>
                    <li><strong>Contract Workflow Tests</strong> - Testing business rules (service request creation only for Active contracts, expired detection)</li>
                </ul>

                <div class="alert alert-success mt-3">
                    <strong>Summary:</strong> This system provides a complete logistics management solution with client management, contract tracking, service request processing, real-time currency conversion, PDF document handling, role-based access control, and comprehensive business rule enforcement. All components are unit tested to ensure reliability.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .bi {
            margin-right: 5px;
        }

        h6 {
            color: #2c3e50;
            font-weight: bold;
            margin-top: 10px;
        }

        hr {
            margin: 20px 0;
        }
    </style>
}