@model St10439541_PROG7311_P2.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<h1>Contract Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            Client
        </dt>
        <dd class="col-sm-9">
            @Model.Client?.Name
        </dd>
        <dt class="col-sm-3">
            Start Date
        </dt>
        <dd class="col-sm-9">
            @Model.StartDate.ToString("dd/MM/yyyy")
        </dd>
        <dt class="col-sm-3">
            End Date
        </dt>
        <dd class="col-sm-9">
            @Model.EndDate.ToString("dd/MM/yyyy")
        </dd>
        <dt class="col-sm-3">
            Status
        </dt>
        <dd class="col-sm-9">
            <span class="badge bg-@(Model.Status.ToString() switch {
                "Active" => "success",
                "Draft" => "secondary",
                "Expired" => "danger",
                "OnHold" => "warning",
                "PendingClientSignature" => "info",
                _ => "light"
            })">
                @(Model.Status == ContractStatus.PendingClientSignature ? "Pending Signature" : Model.Status.ToString())
            </span>
        </dd>
        <dt class="col-sm-3">
            Service Level
        </dt>
        <dd class="col-sm-9">
            @Model.ServiceLevel
        </dd>
        <dt class="col-sm-3">
            Terms & Conditions
        </dt>
        <dd class="col-sm-9">
            @(string.IsNullOrEmpty(Model.TermsAndConditions) ? "No terms specified" : Model.TermsAndConditions)
        </dd>
        <dt class="col-sm-3">
            Signed Agreement
        </dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.PdfFilePath))
            {
                <a asp-action="DownloadPdf" asp-route-id="@Model.ContractId" class="btn btn-sm btn-primary">Download PDF</a>
            }
            else
            {
                <span class="text-muted">No PDF uploaded</span>
            }
        </dd>
    </dl>
</div>

<h3>Service Requests</h3>
@if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Request ID</th>
                <th>Description</th>
                <th>Amount (USD)</th>
                <th>Amount (ZAR)</th>
                <th>Status</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model.ServiceRequests)
            {
                <tr>
                    <td>@request.ServiceRequestId</td>
                    <td>@request.Description</td>
                    <td>$@(request.AmountUSD.ToString("N2"))</td>
                    <td>R@(request.AmountZAR.ToString("N2"))</td>
                    <td>
                        <span class="badge bg-@(request.Status.ToString() switch {
                            "Pending" => "warning",
                            "InProgress" => "info",
                            "Completed" => "success",
                            "Cancelled" => "danger",
                            _ => "secondary"
                        })">
                            @request.Status
                        </span>
                     </td>
                    <td>@request.CreatedAt.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No service requests found for this contract.</p>
}

<div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-warning">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>