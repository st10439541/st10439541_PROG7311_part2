@model IEnumerable<St10439541_PROG7311_P2.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Contract</a>
    </p>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Search/Filter Section -->
<div class="card mb-4">
    <div class="card-header">
        <h5>Filter Contracts</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row">
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Start Date From:</label>
                    <input type="date" id="startDate" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">End Date To:</label>
                    <input type="date" id="endDate" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Status:</label>
                    <select id="status" name="status" class="form-select" asp-items="Html.GetEnumSelectList<St10439541_PROG7311_P2.Models.ContractStatus>()">
                        <option value="">All</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Apply Filters</button>
                    <a asp-action="Index" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Client</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Service Level</th>
                <th>Signed</th>
                <th>PDF</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Client?.Name</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td>
                        @{
                            string badgeClass = item.Status.ToString() switch
                            {
                                "Active" => "success",
                                "Draft" => "secondary",
                                "Expired" => "danger",
                                "OnHold" => "warning",
                                "PendingClientSignature" => "info",
                                _ => "light"
                            };
                        }
                        <span class="badge bg-@badgeClass">
                            @(item.Status == ContractStatus.PendingClientSignature ? "Pending Signature" : item.Status.ToString())
                        </span>
                    </td>
                    <td>@item.ServiceLevel</td>
                    <td>
                        @if (item.IsSignedByClient)
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> Signed
                            </span>
                            <br />
                            <small class="text-muted">@item.SignatureDate?.ToShortDateString()</small>
                        }
                        else
                        {
                            <span class="badge bg-warning">Not Signed</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.PdfFilePath))
                        {
                            <a asp-action="DownloadPdf" asp-route-id="@item.ContractId" class="btn btn-sm btn-secondary">
                                <i class="bi bi-download"></i> Download PDF
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No PDF</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@item.ContractId" class="btn btn-sm btn-info">
                                <i class="bi bi-info-circle"></i> Details
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.ContractId" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ContractId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            }
                            else if (User.IsInRole("User") && item.Status == ContractStatus.PendingClientSignature && !item.IsSignedByClient)
                            {
                                <a asp-action="Sign" asp-route-id="@item.ContractId" class="btn btn-sm btn-success">
                                    <i class="bi bi-pen"></i> Sign Contract
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle"></i> No contracts found.
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create">Click here to create your first contract.</a>
        }
    </div>
}

@section Scripts {
    <style>
        .btn-group {
            gap: 5px;
        }
        .table td {
            vertical-align: middle;
        }
        .bi {
            margin-right: 3px;
        }
    </style>
}