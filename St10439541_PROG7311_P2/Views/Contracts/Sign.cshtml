@model St10439541_PROG7311_P2.Models.Contract

@{
    ViewData["Title"] = "Sign Contract";
}

<h1>Sign Contract</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">Contract Details</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">
                        Client
                    </dt>
                    <dd class="col-sm-8">
                        @Model.Client?.Name
                    </dd>
                    <dt class="col-sm-4">
                        Start Date
                    </dt>
                    <dd class="col-sm-8">
                        @Model.StartDate.ToShortDateString()
                    </dd>
                    <dt class="col-sm-4">
                        End Date
                    </dt>
                    <dd class="col-sm-8">
                        @Model.EndDate.ToShortDateString()
                    </dd>
                    <dt class="col-sm-4">
                        Service Level
                    </dt>
                    <dd class="col-sm-8">
                        @Model.ServiceLevel
                    </dd>
                    <dt class="col-sm-4">
                        Terms & Conditions
                    </dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrEmpty(Model.TermsAndConditions) ? "No terms specified" : Model.TermsAndConditions)
                    </dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.PdfFilePath))
                {
                    <div class="alert alert-info">
                        <strong>Contract Document:</strong>
                        <a asp-action="DownloadPdf" asp-route-id="@Model.ContractId" class="btn btn-sm btn-info ms-2">View Contract PDF</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Sign Contract</h4>
            </div>
            <div class="card-body">
                <form asp-action="Sign" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="ContractId" />

                    <div class="form-group mb-3">
                        <label class="control-label">Upload Signed PDF</label>
                        <input type="file" name="SignedPdfFile" class="form-control" accept=".pdf" required />
                        <small class="text-muted">Please upload the signed contract PDF.</small>
                    </div>

                    <div class="alert alert-warning">
                        <strong>Important:</strong>
                        <p class="mb-0">By signing this contract, you agree to all terms and conditions. The contract will become active immediately after signing.</p>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success w-100">Sign Contract</button>
                    </div>
                </form>
            </div>
            <div class="card-footer">
                <a asp-action="Index" class="btn btn-secondary">Back to Contracts</a>
            </div>
        </div>
    </div>
</div>