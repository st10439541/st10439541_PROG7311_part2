@model St10439541_PROG7311_P2.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h1>Delete Service Request</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this service request?</h3>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            Client
        </dt>
        <dd class="col-sm-9">
            @(Model.Contract?.Client?.Name ?? "N/A")
        </dd>
        <dt class="col-sm-3">
            Service Description
        </dt>
        <dd class="col-sm-9">
            @Model.Description
        </dd>
        <dt class="col-sm-3">
            Amount (USD)
        </dt>
        <dd class="col-sm-9">
            $@(Model.AmountUSD.ToString("N2"))
        </dd>
        <dt class="col-sm-3">
            Amount (ZAR)
        </dt>
        <dd class="col-sm-9">
            R@(Model.AmountZAR.ToString("N2"))
        </dd>
        <dt class="col-sm-3">
            Status
        </dt>
        <dd class="col-sm-9">
            @if (Model.Status == RequestStatus.Pending)
            {
                <span class="badge bg-warning">Pending</span>
            }
            else if (Model.Status == RequestStatus.Accepted)
            {
                <span class="badge bg-success">Accepted</span>
            }
            else if (Model.Status == RequestStatus.Denied)
            {
                <span class="badge bg-danger">Denied</span>
            }
            else
            {
                <span class="badge bg-secondary">@Model.Status</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ServiceRequestId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>