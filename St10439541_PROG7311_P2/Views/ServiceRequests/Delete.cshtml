@model St10439541_PROG7311_P2.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h1>Delete Service Request</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this service request?</h3>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            Client
        </dt>
        <dd class="col-sm-9">
            @Model.Contract?.Client?.Name
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.AmountUSD)
        </dt>
        <dd class="col-sm-9">
            $@Model.AmountUSD.ToString("F2")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.AmountZAR)
        </dt>
        <dd class="col-sm-9">
            R@Model.AmountZAR.ToString("F2")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ServiceRequestId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>