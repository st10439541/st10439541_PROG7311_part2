@model IEnumerable<St10439541_PROG7311_P2.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h1>Service Requests</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Service Request</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Client</th>
                <th>Contract ID</th>
                <th>Description</th>
                <th>Amount (USD)</th>
                <th>Amount (ZAR)</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Contract?.Client?.Name ?? "N/A")</td>
                    <td>@item.ContractId</td>
                    <td>@item.Description</td>
                    <td>$@(item.AmountUSD.ToString("N2"))</td>
                    <td>R@(item.AmountZAR.ToString("N2"))</td>
                    <td>
                        @if (item.Status == RequestStatus.Pending)
                        {
                            <span class="badge bg-warning">Pending</span>
                        }
                        else if (item.Status == RequestStatus.Accepted)
                        {
                            <span class="badge bg-success">Accepted</span>
                        }
                        else if (item.Status == RequestStatus.Denied)
                        {
                            <span class="badge bg-danger">Denied</span>
                        }
                        else if (item.Status == RequestStatus.InProgress)
                        {
                            <span class="badge bg-info">In Progress</span>
                        }
                        else if (item.Status == RequestStatus.Completed)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else if (item.Status == RequestStatus.Cancelled)
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                    </td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-info">Details</a>

                            @if (User.IsInRole("Admin"))
                            {
                                if (item.Status == RequestStatus.Pending)
                                {
                                    <a asp-action="Accept" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-success">Accept</a>
                                    <a asp-action="Deny" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-danger">Deny</a>
                                }
                                <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No service requests found. <a asp-action="Create">Create one here</a>
    </div>
}

@section Scripts {
    <style>
        .btn-group {
            gap: 5px;
        }

        .table td {
            vertical-align: middle;
        }
    </style>
}