@model IEnumerable<St10439541_PROG7311_P2.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h1>Service Requests</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Service Request</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Contract</th>
            <th>Description</th>
            <th>Amount (USD)</th>
            <th>Amount (ZAR)</th>
            <th>Status</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Contract?.Client?.Name</td>
                <td>@item.ContractId</td>
                <td>@item.Description</td>
                <td>$@item.AmountUSD.ToString("F2")</td>
                <td>R@item.AmountZAR.ToString("F2")</td>
                <td>
                    <span class="badge bg-@(item.Status.ToString() switch {
                        "Pending" => "warning",
                        "InProgress" => "info",
                        "Completed" => "success",
                        "Cancelled" => "danger",
                        _ => "secondary"
                    })">
                        @item.Status
                    </span>
                </td>
                <td>@item.CreatedAt.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>