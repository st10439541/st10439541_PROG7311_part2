@model St10439541_PROG7311_P2.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<h1>Service Request Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            Client
        </dt>
        <dd class="col-sm-9">
            @Model.Contract?.Client?.Name
        </dd>
        <dt class="col-sm-3">
            Contract ID
        </dt>
        <dd class="col-sm-9">
            @Model.ContractId
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.AmountUSD)
        </dt>
        <dd class="col-sm-9">
            $@Model.AmountUSD.ToString("F2")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.AmountZAR)
        </dt>
        <dd class="col-sm-9">
            R@Model.AmountZAR.ToString("F2")
        </dd>
        <dt class="col-sm-3">
            Exchange Rate Used
        </dt>
        <dd class="col-sm-9">
            @Model.ExchangeRateUsed.ToString("F4") ZAR per USD
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-9">
            <span class="badge bg-@(Model.Status.ToString() switch {
                "Pending" => "warning",
                "InProgress" => "info",
                "Completed" => "success",
                "Cancelled" => "danger",
                _ => "secondary"
            })">
                @Model.Status
            </span>
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.ServiceRequestId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>