@model St10439541_PROG7311_P2.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<h1>Service Request Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            Client
        </dt>
        <dd class="col-sm-9">
            @(Model.Contract?.Client?.Name ?? "N/A")
        </dd>
        <dt class="col-sm-3">
            Contract ID
        </dt>
        <dd class="col-sm-9">
            @Model.ContractId
        </dd>
        <dt class="col-sm-3">
            Service Description
        </dt>
        <dd class="col-sm-9">
            @Model.Description
        </dd>
        <dt class="col-sm-3">
            Amount (USD)
        </dt>
        <dd class="col-sm-9">
            $@(Model.AmountUSD.ToString("N2"))
        </dd>
        <dt class="col-sm-3">
            Amount (ZAR)
        </dt>
        <dd class="col-sm-9">
            R@(Model.AmountZAR.ToString("N2"))
        </dd>
        <dt class="col-sm-3">
            Exchange Rate Used
        </dt>
        <dd class="col-sm-9">
            @(Model.ExchangeRateUsed.ToString("N4")) ZAR per USD
        </dd>
        <dt class="col-sm-3">
            Status
        </dt>
        <dd class="col-sm-9">
            <span class="badge bg-@(Model.Status.ToString() switch {
                "Pending" => "warning",
                "Accepted" => "success",
                "Denied" => "danger",
                "InProgress" => "info",
                "Completed" => "success",
                "Cancelled" => "danger",
                _ => "secondary"
            })">
                @Model.Status
            </span>
        </dd>
        <dt class="col-sm-3">
            Created At
        </dt>
        <dd class="col-sm-9">
            @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </dd>
        @if (!string.IsNullOrEmpty(Model.AdminComments))
        {
            <dt class="col-sm-3">
                Admin Comments
            </dt>
            <dd class="col-sm-9">
                <div class="alert alert-info">
                    @Model.AdminComments
                </div>
            </dd>
        }
        @if (Model.AdminResponseDate.HasValue)
        {
            <dt class="col-sm-3">
                Response Date
            </dt>
            <dd class="col-sm-9">
                @Model.AdminResponseDate.Value.ToString("dd/MM/yyyy HH:mm")
            </dd>
        }
    </dl>
</div>

<div>
    @if (User.IsInRole("Admin") && Model.Status == RequestStatus.Pending)
    {
        <a asp-action="Accept" asp-route-id="@Model.ServiceRequestId" class="btn btn-success">Accept</a>
        <a asp-action="Deny" asp-route-id="@Model.ServiceRequestId" class="btn btn-danger">Deny</a>
    }
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.ServiceRequestId" class="btn btn-warning">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.ServiceRequestId" class="btn btn-danger">Delete</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>