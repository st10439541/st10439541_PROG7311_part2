@model St10439541_PROG7311_P2.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<h1>Create Client</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Company Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ContactEmail" class="control-label">Contact Email (will be used for login)</label>
                <input asp-for="ContactEmail" class="form-control" type="email" />
                <span asp-validation-for="ContactEmail" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ContactPhone" class="control-label">Contact Phone</label>
                <input asp-for="ContactPhone" class="form-control" />
                <span asp-validation-for="ContactPhone" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Address" class="control-label">Address</label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Region" class="control-label">Region</label>
                <input asp-for="Region" class="form-control" />
                <span asp-validation-for="Region" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SelectedRole" class="control-label">User Role</label>
                <select asp-for="SelectedRole" class="form-control">
                    <option value="User">Client</option>
                    <option value="Admin">Administrator</option>
                </select>
                <span asp-validation-for="SelectedRole" class="text-danger"></span>
                <small class="text-muted">
                    <ul class="mt-1">
                        <li><strong>Client:</strong> Can view contracts, sign contracts, and create service requests</li>
                        <li><strong>Administrator:</strong> Full access to manage clients, contracts, and service requests</li>
                    </ul>
                </small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="control-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <small class="text-muted">Password must be at least 6 characters.</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ConfirmPassword" class="control-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create Client</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}