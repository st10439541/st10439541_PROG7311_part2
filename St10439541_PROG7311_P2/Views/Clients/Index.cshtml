@model IEnumerable<St10439541_PROG7311_P2.Models.Client>

@{
    ViewData["Title"] = "Clients";
    var users = ViewBag.Users as IEnumerable<St10439541_PROG7311_P2.Models.User>;
    var userPasswords = ViewBag.UserPasswords as Dictionary<int, string>;
}

<h1>Clients</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Client</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Filter Section -->
<div class="card mb-4">
    <div class="card-header">
        <h5>Filter Users by Role</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row">
                <div class="col-md-4">
                    <label for="roleFilter" class="form-label">Role:</label>
                    <select id="roleFilter" name="roleFilter" class="form-select">
                        <option value="">All Users</option>
                        <option value="Admin">Administrators</option>
                        <option value="User">Clients</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Apply Filter</button>
                    <a asp-action="Index" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Company Name</th>
                <th>Contact Email</th>
                <th>Contact Phone</th>
                <th>Region</th>
                <th>User Role</th>
                <th>Password</th>
                <th>Contracts</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var associatedUser = users?.FirstOrDefault(u => u.ClientId == item.ClientId);
                var userRole = associatedUser != null && associatedUser.IsAdmin ? "Admin" : "Client";
                var roleBadgeClass = userRole == "Admin" ? "bg-danger" : "bg-info";

                string displayPassword = "123456";
                if (userPasswords != null && userPasswords.ContainsKey(item.ClientId))
                {
                    displayPassword = userPasswords[item.ClientId];
                }
                else if (userRole == "Admin")
                {
                    displayPassword = "Admin@123";
                }

                <tr>
                    <td>@item.Name</td>
                    <td>@item.ContactEmail</td>
                    <td>@item.ContactPhone</td>
                    <td>@item.Region</td>
                    <td class="text-center">
                        <span class="badge @roleBadgeClass">@userRole</span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-1">
                            <code style="background-color: #f4f4f4; padding: 4px 8px; border-radius: 4px;">@displayPassword</code>
                            <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('@displayPassword')">Copy</button>
                        </div>
                    </td>
                    <td class="text-center">@item.Contracts?.Count()</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@item.ClientId" class="btn btn-sm btn-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.ClientId" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.ClientId" class="btn btn-sm btn-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No clients found. <a asp-action="Create">Create your first client here</a>
    </div>
}

@section Scripts {
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                var tempAlert = document.createElement("div");
                tempAlert.innerHTML = "Copied: " + text;
                tempAlert.style.position = "fixed";
                tempAlert.style.bottom = "20px";
                tempAlert.style.right = "20px";
                tempAlert.style.backgroundColor = "#28a745";
                tempAlert.style.color = "white";
                tempAlert.style.padding = "10px";
                tempAlert.style.borderRadius = "5px";
                tempAlert.style.zIndex = "9999";
                document.body.appendChild(tempAlert);
                setTimeout(function() {
                    tempAlert.remove();
                }, 2000);
            });
        }
    </script>
    <style>
        .btn-group {
            gap: 5px;
        }

        .table td {
            vertical-align: middle;
        }

        code {
            font-size: 0.85em;
            color: #d63384;
        }
    </style>
}